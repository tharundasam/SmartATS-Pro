# Copy this file to .env and adjust values as needed.
# .env itself is gitignored — never commit real secrets.

APP_NAME=SmartATS Pro API
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# Local dev uses SQLite (file-based, zero setup). For production, switch to:
#   DATABASE_URL=postgresql+psycopg2://user:password@host:5432/smartats
DATABASE_URL=sqlite:///./smartats.db

# Change this to a long random string before any real deployment.
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

UPLOAD_DIR=./storage/resumes
MAX_UPLOAD_SIZE_MB=10
